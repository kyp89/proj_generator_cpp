{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug app",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/ProjGenCpp.exe",
      "args": [
        "--projectName",
        "TESTProject1",
        "--projectPath",
        "D:\\Prywatne\\TESTS",
        "--useSDL",
        "yes"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "preLaunchTask": "Build and Configure"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "d:/Prywatne/CPP/proj_generator_cpp/src",
      "program": "d:/Prywatne/CPP/proj_generator_cpp/src/build/Debug/outDebug",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}