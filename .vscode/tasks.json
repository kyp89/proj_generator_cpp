{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build and Configure",
            "dependsOn": [
                "CMake Configure",
                "CMake Build"
            ],
            "dependsOrder": "sequence"
        },
        {
            "label": "CMake Configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-B", "build",
                "-G", "MinGW Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug"
            ]
        },
        {
            "label": "CMake Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "build",
                "--config", "Debug"
            ]
        }
    ]
}